# R3-MN1 local-first environment
# Usage:  cp .env.r3mn1 .env   (or symlink)
#
# All three inference services run as Docker containers on the local VM
# and expose OpenAI-compatible /v1 endpoints.

# ---------------------------------------------------------------------------
# Provider selection
# ---------------------------------------------------------------------------
PROVIDER=pipecat

# ---------------------------------------------------------------------------
# Profile
# ---------------------------------------------------------------------------
REACHY_MINI_CUSTOM_PROFILE=r3_mn1

# ---------------------------------------------------------------------------
# Local VM
# ---------------------------------------------------------------------------
LOCAL_VM_IP=192.168.178.155

# ---------------------------------------------------------------------------
# LLM  — Qwen3.5-35B-A3B-IQ4_XS via ik-llama.cpp
# ---------------------------------------------------------------------------
LLM_BASE_URL=http://192.168.178.155:3443/v1
# MODEL_NAME is read by both config.py (OpenAI path) and pipecat_provider.py.
# ik-llama.cpp returns the GGUF path unless --alias was set at launch.
# Check with:  curl http://192.168.178.155:3443/v1/models
MODEL_NAME=/models/Qwen3.5-35B-A3B-GGUF/IQ4_XS/Qwen3.5-35B-A3B-IQ4_XS-00001-of-00002.gguf

# ---------------------------------------------------------------------------
# STT / ASR  — Qwen3-ASR via qwen-asr-serve (vLLM)
# ---------------------------------------------------------------------------
ASR_BASE_URL=http://192.168.178.155:8015/v1
# Default vLLM model ID is the HF repo name unless --served-model-name was set.
# Check with:  curl http://192.168.178.155:8015/v1/models
ASR_MODEL=Qwen/Qwen3-ASR-0.6B

# ---------------------------------------------------------------------------
# TTS  — Qwen3-TTS via groxaxo/Qwen3-TTS-Openai-Fastapi
# ---------------------------------------------------------------------------
TTS_BASE_URL=http://192.168.178.155:7034/v1
# Supports: qwen3-tts, tts-1, tts-1-hd, tts-1-en, tts-1-zh, etc.
TTS_MODEL=qwen3-tts

# ---------------------------------------------------------------------------
# Vision (for MCP vision server / --local-vision)
# ---------------------------------------------------------------------------
LOCAL_VISION_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct

# ---------------------------------------------------------------------------
# Reachy Mini robot
# ---------------------------------------------------------------------------
# Used by --robot-name flag; leave blank for SDK auto-detect on local network.
# REACHY_ROBOT_NAME=192.168.178.127

# ---------------------------------------------------------------------------
# Home Assistant
# ---------------------------------------------------------------------------
HA_URL=http://192.168.178.77:8123
# HA_TOKEN=  # Long-lived access token — generate in HA → Profile → Security

# ---------------------------------------------------------------------------
# OpenAI fallback (leave blank to disable; only needed for --provider openai)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=
