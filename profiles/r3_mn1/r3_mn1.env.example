# R3-MN1 local-first environment
# Copy to .env (or export directly) before running:
#   cp profiles/r3_mn1/r3_mn1.env.example .env

# Use the local Pipecat pipeline instead of the OpenAI Realtime API
PROVIDER=pipecat

# Load the R3-MN1 personality profile
REACHY_MINI_CUSTOM_PROFILE=r3_mn1

# --- Local inference endpoints (Docker on VM) ---
# All expose OpenAI-compatible /v1 APIs

# LLM: Qwen3.5-35B-A3B-IQ4_XS via ik-llama.cpp
LLM_BASE_URL=http://192.168.178.155:3443/v1
MODEL_NAME=qwen3:8b

# TTS: Qwen3-TTS
TTS_BASE_URL=http://192.168.178.155:7034/v1

# ASR/STT: Qwen-ASR
ASR_BASE_URL=http://192.168.178.155:8015/v1

# Local vision model for describe_scene() in the vision MCP server
LOCAL_VISION_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct
