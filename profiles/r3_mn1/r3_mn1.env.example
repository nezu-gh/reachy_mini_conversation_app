# R3-MN1 local-first environment
#
# The canonical env file lives at the repo root:
#
#   cp .env.r3mn1 .env          # or: ln -s .env.r3mn1 .env
#
# See .env.r3mn1 for all available variables (LLM, ASR, TTS endpoints,
# model names, Home Assistant, etc.).
#
# Minimum required for the local pipeline:
#   PROVIDER=pipecat
#   REACHY_MINI_CUSTOM_PROFILE=r3_mn1
#   LLM_BASE_URL=http://<vm-ip>:3443/v1
#   ASR_BASE_URL=http://<vm-ip>:8015/v1
#   TTS_BASE_URL=http://<vm-ip>:7034/v1
